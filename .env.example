# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must never be committed — see enshrly/settings.py for how these are read.

DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_SECRET_KEY=
# Optional production hardening (all default sensibly off while DJANGO_DEBUG=True):
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_HSTS_SECONDS=31536000

# Fernet key encrypting WordPressSite.application_password in the DB.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Infobip (WhatsApp OTP / notifications) — https://www.infobip.com
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
INFOBIP_SENDER=

# Local wallet transfer confirmation API (mobile app / worker integration)
WALLET_API_KEY=
WALLET_NUMBER=
PAIRING_TOKEN=

# PayPal — https://developer.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live

# Paymob — https://accept.paymob.com
PAYMOB_API_KEY=
PAYMOB_HMAC_KEY=
PAYMOB_CARD_INTEGRATION_ID=5792603
PAYMOB_IFRAME_ID=1063704
